{
  "name": "ai-worktrees",
  "version": "0.1.0",
  "description": "Local Mac app for managing AI coding-agent worktree sessions across repos",
  "main": "out/main/index.js",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "rebuild": "electron-rebuild -f -w node-pty",
    "fix-pty-perms": "chmod +x node_modules/node-pty/prebuilds/*/spawn-helper 2>/dev/null || true",
    "postinstall": "electron-builder install-app-deps && npm run fix-pty-perms",
    "dist": "electron-vite build && electron-builder --mac",
    "dist:ci": "electron-vite build && electron-builder --mac --publish never",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "npx tsx --test src/main/agents.test.ts src/main/global-session-cwd.test.ts src/shared/worktrees-skills.test.ts src/shared/settings-import-export.test.ts"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0"
  },
  "build": {
    "appId": "com.jamessherburn.ai-worktrees",
    "productName": "AI Worktrees",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon-source-1024.png",
        "to": "icon-source-1024.png"
      },
      {
        "from": "build/icon-source-1024-light.png",
        "to": "icon-source-1024-light.png"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.icns"
    },
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ]
  }
}
